# Локальная конфигурация inference-сервера для веб-интерфейсов
#
# Использование:
#   mkdir -p ~/.config/ai-plant
#   cp scripts/webui/inference.env.example ~/.config/ai-plant/inference.env
#   $EDITOR ~/.config/ai-plant/inference.env
#
# Файл читается через source в scripts/webui/config.sh.
# Все веб-UI (open-webui, lobe-chat) автоматически подхватят значения.
#
# Приоритет: значения из этого файла > дефолты в config.sh.

# Хост llama-server (для health-check с host-стороны).
# Обычно localhost. Меняй только если inference крутится на удалённой машине.
LLAMA_HOST=localhost

# Порт chat API (OpenAI-совместимый /v1/chat/completions).
# Дефолт в репо -- 8080. Если запускаешь через vulkan/preset/*.sh -- обычно 8081.
LLAMA_PORT=8081

# Порт FIM-сервера (автодополнение кода).
LLAMA_FIM_PORT=8080
