# Локальная конфигурация inference-сервера для веб-интерфейсов
#
# Использование:
#   mkdir -p ~/.config/ai-plant
#   cp scripts/webui/inference.env.example ~/.config/ai-plant/inference.env
#   $EDITOR ~/.config/ai-plant/inference.env
#
# Файл читается через source в scripts/webui/config.sh.
# Все веб-UI (open-webui, lobe-chat) автоматически подхватят значения.
#
# Приоритет: значения из этого файла > дефолты в config.sh.

# Хост llama-server.
# - localhost (или 127.0.0.1) -- inference на той же машине, что и Docker.
#   Docker автоматически использует host.docker.internal.
# - <IP> (например 192.168.1.77) -- inference на удалённой машине, Docker
#   ходит напрямую по этому адресу.
LLAMA_HOST=localhost

# Порт chat API (OpenAI-совместимый /v1/chat/completions).
# Дефолт в репо -- 8080. При запуске через vulkan/preset/*.sh -- обычно 8081.
LLAMA_PORT=8081

# Порт FIM-сервера (автодополнение кода).
LLAMA_FIM_PORT=8080

# Опционально: явный URL целиком (переопределяет LLAMA_HOST/PORT).
# Полезно для нестандартных схем, прокси, https и т.д.
# LLAMA_API_URL=http://192.168.1.77:8081/v1
